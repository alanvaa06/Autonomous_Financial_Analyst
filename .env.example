# ============================================================================
# LOCAL DEVELOPMENT ONLY — do NOT set these as HF Space Secrets on a public
# Space. Public Space is BYO-key: each user pastes their own keys in the UI.
# ============================================================================
#
# On a public HF Space with any ANTHROPIC_API_KEY set as a Space Secret, every
# visitor would be billed against your key. That's why env-var bootstrap is
# DISABLED by default. To re-enable for local dev, set ALLOW_ENV_KEYS=1.

ALLOW_ENV_KEYS=1

ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
TAVILY_API_KEY=tvly-your-tavily-key-here

# Optional — override the base-corpus PDF folder (default: App/data/Companies-AI-Initiatives/)
# PDF_DIR=/absolute/path/to/pdfs
